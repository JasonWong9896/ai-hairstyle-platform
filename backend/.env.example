DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_hairstyle
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
PUBLIC_API_URL=http://localhost:8000
AUTH_TOKEN_SECRET=change-this-secret
MEMBER_ADMIN_API_KEY=change-this-admin-key

# Email delivery
# Recommended for production on Render: use Resend's HTTPS API.
# RESEND_API_KEY=re_your_resend_api_key
# EMAIL_FROM=AI Hairstyle Platform <onboarding@your-domain.com>

# Optional SMTP fallback. Use port 465 with implicit TLS.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Optional direct HTTPS for the Nest backend. In production, prefer a reverse
# proxy such as Caddy/Nginx/Cloudflare in front of the Node services.
# HTTPS_KEY_PATH=C:\certs\localhost-key.pem
# HTTPS_CERT_PATH=C:\certs\localhost-cert.pem

# Stripe Checkout
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
